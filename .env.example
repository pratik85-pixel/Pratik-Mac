# .env.example — ZenFlow Verity
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL used by the FastAPI app (asyncpg)
DATABASE_URL=postgresql+asyncpg://zenflow:zenflow@localhost:5432/zenflow_dev

# Sync URL used by Alembic migrations (psycopg2)
DATABASE_SYNC_URL=postgresql+psycopg2://zenflow:zenflow@localhost:5432/zenflow_dev

# ── LLM (optional — set LLM_ENABLED=false for offline/dev mode) ──────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_ENABLED=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_WEBSOCKET=true
ENABLE_CONVERSATION=true

# ── Live-session processing ───────────────────────────────────────────────────
WINDOW_SECONDS=60
WINDOW_OVERLAP_SECONDS=30
MIN_BEATS_PER_WINDOW=30
