+import java.nio.file.Files
+import java.nio.file.Path
 import java.nio.file.Paths
 
+/** ZenFlow: Android Studio Gradle often has no `node` on PATH; respect NODE_BINARY in env / local.properties. */
+class ExpoAutolinkingNodeResolver {
+  /** Prefer symlink-safe NIO checks over File.isFile() (nvm/Homebrew shims). */
+  static String pickExecutable(String raw) {
+    if (raw == null) return null
+    def t = raw.trim()
+    if (t.isEmpty()) return null
+    try {
+      Path p = Paths.get(t).toAbsolutePath().normalize()
+      if (!Files.exists(p)) return null
+      Path use = p
+      try {
+        use = p.toRealPath()
+      } catch (Throwable ignored) {
+        use = p
+      }
+      if (Files.isExecutable(use)) return use.toString()
+      if (Files.isRegularFile(use)) return use.toString()
+    } catch (Throwable ignored) { }
+    return null
+  }
+
+  static String resolve(File projectDir, Object gradleRef = null) {
+    File root = projectDir != null ? projectDir : new File(System.getProperty('user.dir', '.'))
+    try {
+      if (gradleRef != null && gradleRef.ext?.has('zenflowNodeBinary')) {
+        def g = pickExecutable(gradleRef.ext.zenflowNodeBinary.toString())
+        if (g != null) return g
+      }
+    } catch (Throwable ignored) { }
+    def sp = pickExecutable(System.getProperty('NODE_BINARY'))
+    if (sp != null) return sp
+    def env = pickExecutable(System.getenv('NODE_BINARY'))
+    if (env != null) return env
+    try {
+      def lp = new File(root, 'local.properties')
+      if (lp.exists()) {
+        def props = new Properties()
+        lp.withInputStream { props.load(it) }
+        def p = pickExecutable(props.getProperty('NODE_BINARY'))
+        if (p != null) return p
+      }
+    } catch (Throwable ignored) { }
+    try {
+      def gp = new File(root, 'gradle.properties')
+      if (gp.exists()) {
+        def props = new Properties()
+        gp.withInputStream { props.load(it) }
+        def p = pickExecutable(props.getProperty('NODE_BINARY'))
+        if (p != null) return p
+      }
+    } catch (Throwable ignored) { }
+    def brew = pickExecutable('/opt/homebrew/bin/node')
+    if (brew != null) return brew
+    def usrLocal = pickExecutable('/usr/local/bin/node')
+    if (usrLocal != null) return usrLocal
+    def usrBin = pickExecutable('/usr/bin/node')
+    if (usrBin != null) return usrBin
+    def win = pickExecutable('C:/Program Files/nodejs/node.exe')
+    if (win != null) return win
+    try {
+      def os = System.getProperty('os.name', '').toLowerCase()
+      if (os.contains('windows')) {
+        def proc = ['cmd', '/c', 'where node'].execute(null, root)
+        proc.waitFor()
+        if (proc.exitValue() == 0) {
+          def line = proc.text.readLines().find { it && pickExecutable(it.trim()) != null }
+          if (line) return pickExecutable(line.trim())
+        }
+      } else {
+        def proc = ['/bin/bash', '-lc', 'command -v node'].execute(null, root)
+        proc.waitFor()
+        if (proc.exitValue() == 0) {
+          def line = proc.text.readLines().find { it && pickExecutable(it.trim()) != null }
+          if (line) return pickExecutable(line.trim())
+        }
+      }
+    } catch (Throwable ignored) { }
+    throw new GradleException(
+      "ZenFlow: could not resolve Node for Expo autolinking. Set NODE_BINARY in android/local.properties (run: which node), " +
+      "or pass -DNODE_BINARY=/path/to/node in org.gradle.jvmargs in android/gradle.properties."
+    )
+  }
+}
 
