"""
config/environments/development.env

Development overrides.
Copy to .env (gitignored) and fill in secrets.

All values here override defaults in config/*.py when the app starts.
Only set values that differ from production defaults.
"""

# Database
DATABASE_URL=postgresql+asyncpg://zenflow:zenflow@localhost:5432/zenflow_dev

# OpenAI (required for AI coach)
OPENAI_API_KEY=sk-your-key-here

# ElevenLabs (optional — coach voice)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here

# Feature flags — enable experimental features in dev
ZENFLOW_FEATURE_ENABLE_PAV_BREATH=false
ZENFLOW_FEATURE_ENABLE_SPO2_TREND=false
ZENFLOW_FEATURE_ENABLE_CONVERSATION=true

# Coach
ZENFLOW_COACH_LLM_MODEL=gpt-4o-mini
ZENFLOW_COACH_LLM_TEMPERATURE=0.7
